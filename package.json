{
  "name": "classroom-nav",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest",
    "lint:md": "npx --no-install markdownlint-cli \"README.md\" \"docs/**/*.md\"",
    "lint": "eslint \"src/**/*.js\"",
    "format": "prettier --write \"**/*.{js,json,md}\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "sqlite3": "^5.1.6",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2"
  },
  "devDependencies": {
    "jest": "^29.5.0",
    "nodemon": "^2.0.22",
    "markdownlint-cli": "^0.37.0",
    "husky": "^8.0.3",
    "lint-staged": "^13.2.3",
    "prettier": "^2.8.8",
    "eslint": "^8.50.0"
  },
  "prepare": "husky install",
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write",
      "git add"
    ],
    "*.{json,md,markdown}": [
      "prettier --write",
      "npx --no-install markdownlint-cli",
      "git add"
    ]
  }
}

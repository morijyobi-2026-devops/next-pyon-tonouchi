{
  "name": "next-pyon-suzuryo-tooling",
  "private": true,
  "engines": {
    "node": "24.17.0"
  },
  "scripts": {
    "prepare": "husky",
    "lint": "pnpm run lint:md && pnpm run lint:app",
    "lint:md": "markdownlint-cli2 \"README.md\" \"next-pyon/README.md\" \"docs/**/*.md\"",
    "lint:app": "pnpm --filter next-pyon lint",
    "build": "pnpm --filter ./next-pyon run build",
    "build:app": "pnpm --filter next-pyon build"
  },
  "devDependencies": {
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "markdownlint-cli2": "0.22.1"
  },
  "lint-staged": {
    "*.md": "markdownlint-cli2",
    "next-pyon/**/*.{js,jsx,ts,tsx}": "pnpm --filter next-pyon exec eslint"
  }
}
